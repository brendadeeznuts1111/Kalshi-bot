{
  "name": "kalshi-bot-research",
  "version": "0.2.0",
  "private": true,
  "description": "Discover and rank public Kalshi trading bots on GitHub (Bun + gh CLI)",
  "type": "module",
  "scripts": {
    "research": "bun src/research/cli.ts",
    "export-audit": "bun src/research/export-audit-cli.ts",
    "audit:export": "bun src/research/export-audit-cli.ts",
    "serve": "bun --hot src/research/serve.ts",
    "serve:once": "bun src/research/serve.ts",
    "schedule:register": "bun src/research/schedule-cli.ts register",
    "schedule:remove": "bun src/research/schedule-cli.ts remove",
    "schedule:preview": "bun src/research/schedule-cli.ts preview",
    "dashboard": "bun src/agent/dashboard.ts",
    "dashboard:webview": "bun src/agent/dashboard.ts --webview --open=false",
    "agent": "bun src/agent/cli.ts",
    "report:term": "bun src/agent/report-term.ts",
    "report:diff": "bun src/agent/report-term.ts research/reports/latest.diff.md",
    "test": "bun test",
    "posttest": "bun tools/restore-committed-artifacts.ts",
    "reports:restore": "bun tools/restore-committed-artifacts.ts",
    "artifacts:restore": "bun tools/restore-committed-artifacts.ts",
    "check": "bun run typecheck && bun test",
    "rate-limit:status": "bun tools/github-rate-budget.ts",
    "hooks:install": "cp tools/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
