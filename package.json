{
  "name": "kalshi-bot-research",
  "version": "0.2.0",
  "private": true,
  "description": "Discover and rank public Kalshi trading bots on GitHub (Bun + gh CLI)",
  "type": "module",
  "scripts": {
    "research": "bun src/research/cli.ts",
    "research:dry": "bun src/research/cli.ts --dry-run --offline",
    "export-audit": "bun src/research/export-audit-cli.ts",
    "audit:export": "bun src/research/export-audit-cli.ts",
    "serve": "bun --hot src/research/serve.ts",
    "serve:once": "bun src/research/serve.ts",
    "schedule:register": "bun src/research/schedule-cli.ts register",
    "schedule:remove": "bun src/research/schedule-cli.ts remove",
    "schedule:preview": "bun src/research/schedule-cli.ts preview",
    "agent": "bun src/agent/cli.ts",
    "report:term": "bun src/agent/report-term.ts",
    "report:diff": "bun src/agent/report-term.ts research/reports/latest.diff.md",
    "test": "bun test --isolate",
    "posttest": "bun tools/restore-committed-artifacts.ts",
    "reports:restore": "bun tools/restore-committed-artifacts.ts",
    "artifacts:restore": "bun tools/restore-committed-artifacts.ts",
    "check": "bun run typecheck && bun test",
    "rate-limit:status": "bun tools/github-rate-budget.ts",
    "miss-taxonomy:status": "bun tools/miss-taxonomy-status.ts",
    "hooks:install": "cp tools/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit",
    "cache:purge-ineligible": "bun tools/purge-ineligible-runs.ts",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "alpha:init": "bun src/calibration/init-program.ts",
    "calibration:watcher": "bun src/calibration/cli.ts",
    "calibration:mark-toxicity": "bun src/calibration/mark-toxicity.ts",
    "calibration:resolve-outcomes": "bun src/calibration/resolve-outcomes.ts",
    "calibration:maintenance": "bun src/calibration/maintenance.ts",
    "calibration:toxicity:loop": "bun src/calibration/toxicity-loop.ts",
    "calibration:toxicity:register": "bun src/calibration/toxicity-schedule-cli.ts register",
    "calibration:toxicity:preview": "bun src/calibration/toxicity-schedule-cli.ts preview",
    "alpha:run": "bun src/alpha/run-shadow-once.ts",
    "tennis:events": "bun tools/tennis/events-cli.ts",
    "tennis:itf": "bun tools/tennis/itf-calendar-cli.ts",
    "tennis:record": "bun tools/tennis/record-cli.ts",
    "tennis:ws-ground": "bun tools/tennis/tennis-ws-ground-cli.ts",
    "tennis:collect": "bun tools/tennis/collect-results-cli.ts",
    "tennis:live": "bun tools/tennis/live-scores-cli.ts",
    "tennis:live:canary": "bun tools/tennis/live-scores-cli.ts --canary",
    "tennis:live:canary:register": "bun tools/tennis/live-canary-schedule-cli.ts register",
    "tennis:live:canary:remove": "bun tools/tennis/live-canary-schedule-cli.ts remove",
    "tennis:live:canary:preview": "bun tools/tennis/live-canary-schedule-cli.ts preview",
    "tennis:live:cadence": "bun tools/tennis/live-scores-cli.ts --cadence"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}
