# Kalshi-bot research — copy to .env (gitignored) and adjust locally.

# Popularity gate overrides (optional)
# RESEARCH_MIN_STARS=5
# RESEARCH_MIN_FORKS=3
# RESEARCH_MAX_AGE_MONTHS=18
# RESEARCH_SHORTLIST=12

# Report browser
# PORT=3456

# OS cron (see docs/CRON.md)
# RESEARCH_CRON_SCHEDULE=0 6 * * MON
# RESEARCH_CRON_TITLE=kalshi-research-weekly

# Scheduled runs: export audit when high-value candidates exist
# RESEARCH_EXPORT_AUDIT=1
