# Dependencies & tooling
node_modules/
.bun-cache/
coverage/
.DS_Store

# Local secrets (never commit)
.env
.env.*
!.env.example

# Machine-local runtime (regenerated each run)
research/cache/
research/outputs/
research/exports/
research/evidence/
research/evidence-captures/

# Test artifacts (never commit)
tests/.tmp-*

# Alpha tenant runtime (programs committed; logs are not)
alpha/*/shadow-log.jsonl
calibration/artifacts/

# Bun sqlite footgun: `:memory:<name>` is a cwd file, not RAM (use exact `:memory:` or tests/.tmp-*)
:memory:*

# Per-run markdown snapshots (canonical history: cache.db + latest.md)
research/reports/run_*.md

# Committed on purpose (do not ignore):
#   research/reports/latest.md
#   research/reports/latest.md.fixture   ← posttest restore SSOT
#   research/reports/latest.diff.md
#   research/reports/latest.diff.md.fixture
#   research/audit-evidence/*.jsonl
#   research/queries.json, weights.json, keywords.json, schemas/
